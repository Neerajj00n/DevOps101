## Security Groups

```bash
# Create a security group
aws ec2 create-security-group \
  --group-name web-sg \
  --description "Web server security group" \
  --vpc-id vpc-0xxxxxxxxxxxxxxxx

# Allow HTTP from anywhere
aws ec2 authorize-security-group-ingress \
  --group-id sg-0xxxxxxxxxxxxxxxx \
  --protocol tcp \
  --port 80 \
  --cidr 0.0.0.0/0

# Allow SSH from your IP only
aws ec2 authorize-security-group-ingress \
  --group-id sg-0xxxxxxxxxxxxxxxx \
  --protocol tcp \
  --port 22 \
  --cidr $(curl -s ifconfig.me)/32

# Allow traffic from another security group (common for DB → App)
aws ec2 authorize-security-group-ingress \
  --group-id sg-db-id \
  --protocol tcp \
  --port 5432 \
  --source-group sg-app-id

# List rules for a group
aws ec2 describe-security-groups \
  --group-ids sg-0xxxxxxxxxxxxxxxx \
  --query 'SecurityGroups[0].IpPermissions' \
  --output table
```

