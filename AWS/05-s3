## Basic Operations

```bash
# Create a bucket
aws s3api create-bucket \
  --bucket my-app-bucket-joon \
  --region ap-south-1 \
  --create-bucket-configuration LocationConstraint=ap-south-1
# Note: us-east-1 does NOT need --create-bucket-configuration

# List buckets
aws s3 ls

# List objects in a bucket
aws s3 ls s3://my-app-bucket-joon
aws s3 ls s3://my-app-bucket-joon/uploads/ --recursive

# Upload a file
aws s3 cp myfile.txt s3://my-app-bucket-joon/
aws s3 cp myfile.txt s3://my-app-bucket-joon/uploads/myfile.txt

# Upload a directory
aws s3 sync ./dist/ s3://my-app-bucket-joon/frontend/ --delete
# --delete removes objects in S3 that no longer exist locally

# Download
aws s3 cp s3://my-app-bucket-joon/myfile.txt ./
aws s3 sync s3://my-app-bucket-joon/backups/ ./local-backups/

# Delete
aws s3 rm s3://my-app-bucket-joon/myfile.txt
aws s3 rm s3://my-app-bucket-joon/uploads/ --recursive

# Delete a bucket (must be empty first)
aws s3 rb s3://my-app-bucket-joon
aws s3 rb s3://my-app-bucket-joon --force  # empties then deletes
```

